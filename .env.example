# Recommended in the GitHub product snapshot: run `npm run privacy -- secrets:init` to create the local note secret.
# Manual fallback: copy this file to .env and fill values locally.
# Never commit .env. Never paste private keys or note passwords into chat.

# Disposable low-value Base wallet private key.
# The CLI accepts a single 32-byte hex key with or without 0x.
# Do not use a main wallet, mnemonic phrase, seed phrase, or JSON keystore.
PRIVATE_KEY=

# Base mainnet only for this hackathon product.
X402_CHAIN=base
BASE_RPC_URL=https://mainnet.base.org

# Local encrypted px402 note storage.
# By default the adapter creates a local secret vault at:
# ./data/secrets/px402-note-password.json
# That file is gitignored and the password is never printed.
# Optional override only if you intentionally want external secret management:
# PX402_NOTE_PASSWORD=
# PX402_NOTE_SECRET_FILE=./data/secrets/px402-note-password.json
NOTE_DIR=./data/notes
RECEIPT_DIR=./data/receipts
RESPONSE_DIR=./data/responses
RECOVERY_DIR=./data/recovery

# PRXVT SDK currently downloads remote wasm/zkey files without local hash pinning.
# Leave empty for no-spend review and dry-runs.
# For hackathon-only real spend, set exactly:
# PRXVT_REMOTE_CIRCUITS_ACK=I_UNDERSTAND_UNPINNED_REMOTE_CIRCUITS
PRXVT_REMOTE_CIRCUITS_ACK=

# Spend policy.
MAX_USD_PER_CALL=0.02
MONTHLY_BUDGET_USD=20
MIN_BASE_ETH_BUFFER=0.00005

# 0x Gasless onboarding.
# Required if the disposable wallet has Base USDC but too little native Base ETH for px402 deposit gas.
0X_API_KEY=
ZEROX_API_KEY=
ZEROX_CHAIN_ID=8453
ZEROX_DUST_USDC=0.1

# Trade research demo defaults.
CMC_SYMBOL=ETH
EXA_QUERY=Ethereum market structure and Base ecosystem catalyst
EXA_NUM_RESULTS=3

# Existing weather smoke test.
X402_WEATHER_URL=https://httpay.xyz/api/weather?lat=22.3193&lon=114.1694

# Curvy/crops privacy adapter experiments are retained for research only.
CURVY_ENV=testnet
